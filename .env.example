NEON_DATABASE_URL=your_neon_database_url

# Neon Auth — Get from: Neon Console → Auth section
NEON_AUTH_URL=https://ep-your-branch-id.neonauth.your-region.aws.neon.tech/neondb/auth
VITE_NEON_AUTH_URL=http://localhost:5173/neon-auth/auth

AUTH_SECRET=your_long_random_secret

# Optional: explicitly enable mock database mode for local development without Neon
# USE_MOCK_DB=true

# Optional: allow insecure cookies (no Secure flag) in local development
# ONLY for http://localhost testing — NEVER in production
# ALLOW_INSECURE_COOKIES=true

# Optional: Gemini API key for AI chat features (can also be set per-user in app preferences)
# GEMINI_API_KEY=your_gemini_api_key
