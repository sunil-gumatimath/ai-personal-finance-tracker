{
    "buildCommand": "npm run build:npm",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/handler"
        },
        {
            "source": "/neon-auth/auth/:path*",
            "destination": "https://ep-odd-block-a13wgvy0.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ]
}
